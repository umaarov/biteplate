{
  "realm": "biteplate",
  "enabled": true,
  "displayName": "BitePlate",
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      { "name": "manager", "description": "Full access" },
      { "name": "head_chef", "description": "Runs the kitchen queue" },
      { "name": "waiter", "description": "Takes orders" },
      { "name": "cashier", "description": "Closes bills" }
    ]
  },
  "clients": [
    {
      "clientId": "biteplate-pos",
      "name": "BitePlate POS",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "biteplate-pos-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:8000/*"],
      "webOrigins": ["*"],
      "defaultClientScopes": ["roles", "profile", "email"]
    }
  ],
  "users": [
    {
      "username": "manager",
      "enabled": true,
      "email": "alex.morgan@biteplate.local",
      "firstName": "Alex",
      "lastName": "Morgan",
      "credentials": [{ "type": "password", "value": "manager", "temporary": false }],
      "realmRoles": ["manager"]
    },
    {
      "username": "chef",
      "enabled": true,
      "email": "marco.rossi@biteplate.local",
      "firstName": "Marco",
      "lastName": "Rossi",
      "credentials": [{ "type": "password", "value": "chef", "temporary": false }],
      "realmRoles": ["head_chef"]
    },
    {
      "username": "waiter",
      "enabled": true,
      "email": "sam.lee@biteplate.local",
      "firstName": "Sam",
      "lastName": "Lee",
      "credentials": [{ "type": "password", "value": "waiter", "temporary": false }],
      "realmRoles": ["waiter"]
    },
    {
      "username": "cashier",
      "enabled": true,
      "email": "dana.kerr@biteplate.local",
      "firstName": "Dana",
      "lastName": "Kerr",
      "credentials": [{ "type": "password", "value": "cashier", "temporary": false }],
      "realmRoles": ["cashier"]
    }
  ],
  "components": {
    "org.keycloak.storage.UserStorageProvider": [
      {
        "name": "openldap",
        "providerId": "ldap",
        "config": {
          "enabled": ["true"],
          "priority": ["1"],
          "editMode": ["READ_ONLY"],
          "vendor": ["other"],
          "connectionUrl": ["ldap://openldap:1389"],
          "bindDn": ["cn=admin,dc=biteplate,dc=local"],
          "bindCredential": ["adminpassword"],
          "usersDn": ["ou=people,dc=biteplate,dc=local"],
          "usernameLDAPAttribute": ["uid"],
          "rdnLDAPAttribute": ["uid"],
          "uuidLDAPAttribute": ["entryUUID"],
          "userObjectClasses": ["inetOrgPerson"],
          "searchScope": ["2"],
          "importEnabled": ["true"],
          "syncRegistrations": ["false"]
        },
        "subComponents": {
          "org.keycloak.storage.ldap.mappers.LDAPStorageMapper": [
            {
              "name": "ldap-groups-to-realm-roles",
              "providerId": "role-ldap-mapper",
              "config": {
                "mode": ["READ_ONLY"],
                "roles.dn": ["ou=groups,dc=biteplate,dc=local"],
                "role.name.ldap.attribute": ["cn"],
                "role.object.classes": ["groupOfNames"],
                "membership.ldap.attribute": ["member"],
                "membership.attribute.type": ["DN"],
                "memberof.ldap.attribute": ["memberOf"],
                "use.realm.roles.mapping": ["true"],
                "user.roles.retrieve.strategy": ["LOAD_ROLES_BY_MEMBER_ATTRIBUTE"]
              }
            },
            {
              "name": "email",
              "providerId": "user-attribute-ldap-mapper",
              "config": {
                "ldap.attribute": ["mail"],
                "user.model.attribute": ["email"],
                "read.only": ["true"]
              }
            }
          ]
        }
      }
    ]
  }
}
